# ── Dependencies ──────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js ───────────────────────────────────
/.next/
/out/
/build

# ── Environment variables ─────────────────────
.env*.local
.env

# ── User-uploaded content (never commit) ──────
/public/uploads/*
!/public/uploads/.gitkeep
/data/*
!/data/.gitkeep

# ── Misc ──────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
next-env.d.ts
.vercel
